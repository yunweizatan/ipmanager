<Window x:Class="IPManage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="IP地址资产管理"
        Width="1300"
        Height="800"
        MinWidth="1100"
        MinHeight="680"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.WindowBackground}">

    <Window.Resources>
        <!-- Nav button — active state driven by Tag="True" binding -->
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SidebarActive}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextOnDark}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stat card with left accent bar -->
        <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="18,16" />
        </Style>
    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════
         Root: sidebar (fixed) | gap | main content
         ══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ╔══════════════════╗
             ║   DARK SIDEBAR   ║
             ╚══════════════════╝ -->
        <Border Grid.Column="0" Style="{StaticResource SidebarShellStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo / Brand -->
                <StackPanel Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="10"
                                Background="{DynamicResource Brush.AccentPrimary}">
                            <TextBlock Text="IP"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="IP地址资产管理"
                                       FontSize="14" FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource Brush.TextOnDark}" />
                            <TextBlock Text="IP Asset Manager"
                                       FontSize="10"
                                       Foreground="{DynamicResource Brush.TextOnDarkMuted}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Thin divider -->
                    <Border Height="1" Margin="0,16,0,0"
                            Background="{DynamicResource Brush.SidebarBorder}" />
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <Button Style="{StaticResource NavButtonStyle}"
                            Tag="{Binding IsDashboardSelected}"
                            Command="{Binding NavigateDashboardCommand}"
                            Content="概  览" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Tag="{Binding IsRecordsSelected}"
                            Command="{Binding NavigateRecordsCommand}"
                            Content="记录管理" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Tag="{Binding IsImportSelected}"
                            Command="{Binding NavigateImportCommand}"
                            Content="导入导出" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Tag="{Binding IsBackupSelected}"
                            Command="{Binding NavigateBackupCommand}"
                            Content="备份恢复" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Tag="{Binding IsSettingsSelected}"
                            Command="{Binding NavigateSettingsCommand}"
                            Content="系统设置" />
                </StackPanel>

                <!-- Footer: About button -->
                <Border Grid.Row="2" Margin="0,0,0,10"
                        BorderBrush="{DynamicResource Brush.SidebarBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="0,10,0,0">
                    <Button Style="{StaticResource NavButtonStyle}"
                            Click="OnAboutClick"
                            Content="关于" />
                </Border>
            </Grid>
        </Border>

        <!-- ╔══════════════════════════╗
             ║   MAIN CONTENT AREA      ║
             ╚══════════════════════════╝ -->
        <Grid Grid.Column="1" Margin="16,16,16,16">
            <Grid.RowDefinitions>
                <!-- Top header bar -->
                <RowDefinition Height="Auto" />
                <!-- Stat cards -->
                <RowDefinition Height="Auto" />
                <!-- Page content -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="企业内网 / 本地单机版" />
                    <TextBlock Margin="0,4,0,2"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               Text="{Binding CurrentSectionTitle}" />
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="{Binding CurrentSectionDescription}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Content="刷新" />
                    <Button Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ExportCommand}"
                            Content="导出 CSV" />
                    <Button Margin="8,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnNewRecordClick"
                            Content="+ 新建记录" />
                </StackPanel>
            </Grid>

            <!-- ── Stat Cards ── -->
            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricCaptionStyle}" Text="总记录数" />
                        <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding TotalRecords}" />
                        <TextBlock Style="{StaticResource MetricHintStyle}" Text="全部资产记录" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricCaptionStyle}" Text="使用中" />
                        <TextBlock Style="{StaticResource MetricValueStyle}"
                                   Foreground="{DynamicResource Brush.StatusSuccessForeground}"
                                   Text="{Binding InUseCount}" />
                        <TextBlock Style="{StaticResource MetricHintStyle}" Text="已分配设备" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricCaptionStyle}" Text="空闲地址" />
                        <TextBlock Style="{StaticResource MetricValueStyle}"
                                   Foreground="{DynamicResource Brush.StatusInfoForeground}"
                                   Text="{Binding IdleCount}" />
                        <TextBlock Style="{StaticResource MetricHintStyle}" Text="可继续分配" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricCaptionStyle}" Text="VLAN 数量" />
                        <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding VlanCount}" />
                        <TextBlock Style="{StaticResource MetricHintStyle}" Text="{Binding LastUpdatedSummary}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════
                 PAGE: 概览 Dashboard
                 ══════════════════════════════════════════ -->
            <Grid Grid.Row="2" Visibility="{Binding DashboardVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- Recent records list -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="最近记录" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="按申请时间倒序，展示最近 6 条。" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentRecords}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="14,12"
                                                CornerRadius="10"
                                                Background="{DynamicResource Brush.SurfaceSecondary}"
                                                BorderBrush="{DynamicResource Brush.SurfaceBorder}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                                               Text="{Binding Summary}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                                               Text="{Binding Owner}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Right"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.AccentPrimary}"
                                                               Text="{Binding StatusText}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               HorizontalAlignment="Right"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="{Binding ApplyTimeDisplay}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Quick actions + status distribution -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="快速操作" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="常用功能直接跳转。" />
                            <Button Margin="0,14,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding NavigateRecordsCommand}"
                                    Content="进入记录管理" />
                            <Button Margin="0,8,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding NavigateImportCommand}"
                                    Content="进入导入导出" />
                            <Button Margin="0,8,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding NavigateBackupCommand}"
                                    Content="进入备份恢复" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="状态分布" />
                            <Border Margin="0,12,0,0" Height="1"
                                    Background="{DynamicResource Brush.SurfaceBorder}" />

                            <Grid Margin="0,12,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Text="使用中" />
                                <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.StatusSuccessForeground}"
                                           Text="{Binding InUseCount}" />
                            </Grid>
                            <Grid Margin="0,6,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Text="空闲" />
                                <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.StatusInfoForeground}"
                                           Text="{Binding IdleCount}" />
                            </Grid>
                            <Grid Margin="0,6,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Text="预留" />
                                <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.StatusWarningForeground}"
                                           Text="{Binding ReservedCount}" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Text="停用" />
                                <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="{Binding DisabledCount}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════
                 PAGE: 记录管理
                 ══════════════════════════════════════════ -->
            <Grid Grid.Row="2" Visibility="{Binding RecordsVisibility}">

                <!-- List panel — full width -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- List header + filter toolbar (merged into one row) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Text="记录列表"
                                       VerticalAlignment="Center" />

                            <TextBox Grid.Column="2"
                                     Style="{StaticResource SearchTextBoxStyle}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                            <ComboBox Grid.Column="4"
                                      Height="36"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      ItemsSource="{Binding VlanOptions}"
                                      SelectedItem="{Binding SelectedVlanFilter}" />

                            <ComboBox Grid.Column="6"
                                      Height="36"
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding SelectedStatusFilter}" />

                            <Button Grid.Column="8"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ClearFiltersCommand}"
                                    Content="重置" />
                            <Button Grid.Column="10"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                    Content="{Binding PasswordToggleText}" />
                        </Grid>

                        <!-- spacer row placeholder (row 2 now unused but kept for grid index) -->
                        <Grid Grid.Row="2" Height="0" />

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="4"
                                  x:Name="RecordsGrid"
                                  ItemsSource="{Binding FilteredRecords}"
                                  SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeaderWidth="0"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  MouseDoubleClick="OnDataGridRowDoubleClick"
                                  SelectionChanged="OnDataGridSelectionChanged"
                                  Style="{StaticResource ModernDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="1.2*"  Header="IP 地址"  Binding="{Binding IpAddress}" />
                                <DataGridTextColumn Width="1.3*"  Header="设备名称" Binding="{Binding DeviceName}" />
                                <DataGridTextColumn Width="1*"    Header="使用人"   Binding="{Binding Owner}" />
                                <DataGridTemplateColumn Width="1*" Header="密码">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock x:Name="MaskedPasswordText"
                                                           Text="{Binding MaskedPassword}" />
                                                <TextBlock x:Name="PlainPasswordText"
                                                           Visibility="Collapsed"
                                                           Text="{Binding Password}" />
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowPasswords, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter TargetName="MaskedPasswordText" Property="Visibility" Value="Collapsed" />
                                                    <Setter TargetName="PlainPasswordText" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="0.85*" Header="VLAN"     Binding="{Binding Vlan}" />
                                <DataGridTextColumn Width="1*"    Header="设备类型" Binding="{Binding DeviceType}" />
                                <DataGridTemplateColumn Width="0.85*" Header="状态">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="Badge"
                                                    Padding="10,4"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource Brush.StatusNeutralBackground}">
                                                <TextBlock x:Name="BadgeText"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Brush.StatusNeutralForeground}"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="使用中">
                                                    <Setter TargetName="Badge"    Property="Background" Value="{DynamicResource Brush.StatusSuccessBackground}" />
                                                    <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource Brush.StatusSuccessForeground}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="空闲">
                                                    <Setter TargetName="Badge"    Property="Background" Value="{DynamicResource Brush.StatusInfoBackground}" />
                                                    <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource Brush.StatusInfoForeground}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="预留">
                                                    <Setter TargetName="Badge"    Property="Background" Value="{DynamicResource Brush.StatusWarningBackground}" />
                                                    <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource Brush.StatusWarningForeground}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="停用">
                                                    <Setter TargetName="Badge"    Property="Background" Value="{DynamicResource Brush.StatusDangerBackground}" />
                                                    <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource Brush.StatusDangerForeground}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="1.3*" Header="申请时间" Binding="{Binding ApplyTimeDisplay}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer status -->
                        <Border Grid.Row="6" Style="{StaticResource InlineStatusCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                               Text="{Binding StatusMessage}" />
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="10,0,0,0"
                                               Foreground="{DynamicResource Brush.AccentPrimary}"
                                               Text="{Binding SelectionSummary}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           VerticalAlignment="Center"
                                           Text="Ctrl/Shift 多选" />
                                <Button Grid.Column="3"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding TogglePasswordVisibilityCommand}"
                                        Content="{Binding PasswordToggleText}" />
                                <Button Grid.Column="5"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="OnEditSelectedClick"
                                        Content="编辑" />
                                <Button Grid.Column="7"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding BatchDeleteCommand}"
                                        Content="批量删除" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════
                 PAGE: 导入导出
                 ══════════════════════════════════════════ -->
            <Grid Grid.Row="2" Visibility="{Binding ImportVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="CSV 导入" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="{Binding ImportTemplateHint}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="导入前会先预览前几条记录，失败行会自动生成失败报告。" />
                        <TextBlock Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   Text="{Binding LastImportSummary}" />
                        <Button Margin="0,14,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ImportCsvCommand}"
                                Content="选择 CSV 并导入" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="导出与目录" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="导出当前筛选后的记录，或打开导出目录。" />
                        <Button Margin="0,14,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ExportCommand}"
                                Content="导出当前列表" />
                        <Button Margin="0,8,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenExportsFolderCommand}"
                                Content="打开导出目录" />
                        <TextBlock Margin="0,12,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="{Binding ExportsLocation}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════
                 PAGE: 备份恢复
                 ══════════════════════════════════════════ -->
            <Grid Grid.Row="2" Visibility="{Binding BackupVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="立即备份" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="备份会复制当前索引文件和全部分片 JSON。" />
                        <TextBlock Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   Text="{Binding LastBackupSummary}" />
                        <Button Margin="0,14,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding BackupCommand}"
                                Content="执行一次备份" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="备份目录" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="打开目录查看历史备份文件。" />
                        <TextBlock Margin="0,14,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="{Binding BackupsLocation}" />
                        <Button Margin="0,14,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenBackupsFolderCommand}"
                                Content="打开备份目录" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════
                 PAGE: 系统设置
                 ══════════════════════════════════════════ -->
            <Grid Grid.Row="2" Visibility="{Binding SettingsVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="数据目录" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="程序的主数据、分片、备份和导出都保存在此目录。" />
                        <TextBlock Margin="0,14,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="{Binding DataLocation}" />
                        <Button Margin="0,14,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenDataFolderCommand}"
                                Content="打开数据目录" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="版本说明" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="当前版本支持：中文界面、菜单切换、本地 JSON 存储、CSV 导入导出、筛选查询、备份恢复。" />
                        <TextBlock Margin="0,14,0,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   Text="开发者：抖音 运维杂谈" />
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
