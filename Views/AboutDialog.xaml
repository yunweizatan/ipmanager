<Window x:Class="IPManage.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Width="400"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.WindowBackground}">

    <Border Padding="32,28">
        <StackPanel>

            <!-- Logo + 名称 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="14"
                        Background="{DynamicResource Brush.AccentPrimary}">
                    <TextBlock Text="IP"
                               FontSize="16" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               Text="IP地址资产管理系统" />
                    <TextBlock FontSize="12" Margin="0,3,0,0"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Text="IP Asset Management · v1.0" />
                </StackPanel>
            </StackPanel>

            <!-- Divider -->
            <Border Height="1" Margin="0,20,0,20"
                    Background="{DynamicResource Brush.SurfaceBorder}" />

            <!-- Info rows -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13"
                           Foreground="{DynamicResource Brush.TextSecondary}" Text="开发者" />
                <TextBlock Grid.Row="0" Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.AccentPrimary}" Text="抖音：运维杂谈" />

                <TextBlock Grid.Row="2" Grid.Column="0" FontSize="13"
                           Foreground="{DynamicResource Brush.TextSecondary}" Text="版本" />
                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="13"
                           Foreground="{DynamicResource Brush.TextPrimary}" Text="v1.0.0" />

                <TextBlock Grid.Row="4" Grid.Column="0" FontSize="13"
                           Foreground="{DynamicResource Brush.TextSecondary}" Text="运行环境" />
                <TextBlock Grid.Row="4" Grid.Column="1" FontSize="13"
                           Foreground="{DynamicResource Brush.TextPrimary}" Text=".NET 8 · WPF · 本地单机" />

                <TextBlock Grid.Row="6" Grid.Column="0" FontSize="13"
                           Foreground="{DynamicResource Brush.TextSecondary}" Text="存储方式" />
                <TextBlock Grid.Row="6" Grid.Column="1" FontSize="13"
                           Foreground="{DynamicResource Brush.TextPrimary}" Text="本地 JSON 分片持久化" />

                <TextBlock Grid.Row="8" Grid.Column="0" FontSize="13"
                           Foreground="{DynamicResource Brush.TextSecondary}" Text="功能" />
                <TextBlock Grid.Row="8" Grid.Column="1" FontSize="13"
                           Foreground="{DynamicResource Brush.TextPrimary}"
                           TextWrapping="Wrap"
                           Text="IP地址资产管理 · CSV 导入导出 · 筛选查询 · 备份恢复" />
            </Grid>

            <!-- Divider -->
            <Border Height="1" Margin="0,20,0,20"
                    Background="{DynamicResource Brush.SurfaceBorder}" />

            <!-- Close button -->
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right"
                    IsDefault="True"
                    IsCancel="True"
                    Content="关  闭"
                    Click="OnCloseClick" />

        </StackPanel>
    </Border>
</Window>
